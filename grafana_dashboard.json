{
  "title": "AppSec - SQL Defender Observability",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Eventos por tipo (serie temporal)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (event_type) (count_over_time({job=\"sql_defender\"} | json | __error__=\"\" [1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Distribución por severidad",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (severity) (count_over_time({job=\"sql_defender\"} | json | __error__=\"\" [6h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Tasa de éxito de remediación",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"sql_defender\"} | json | event_type=\"REMEDIATION_SUCCESS\" [6h])) / sum(count_over_time({job=\"sql_defender\"} | json | event_type=~\"REMEDIATION_.*\" [6h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "thresholds": { "steps": [
          { "value": 0, "color": "red" },
          { "value": 0.7, "color": "yellow" },
          { "value": 0.9, "color": "green" }
        ]}}
      }
    },
    {
      "id": 4,
      "title": "Últimos eventos críticos",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"sql_defender\"} | json | severity=\"CRITICAL\"",
          "refId": "A"
        }
      ]
    }
  ]
}
